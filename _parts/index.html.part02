.acc .chev{color:#9A9D92;font-size:15px;transition:transform .2s;flex:none}
.acc[open] .chev{transform:rotate(180deg)}
.acc .abody{padding:0 15px 15px;font-size:15px;line-height:1.7;word-break:keep-all}
.acc .abody p{margin-bottom:8px}
.acc .abody .expert{background:#FBFAF7;border-left:3px solid var(--brand);padding:10px 12px;border-radius:0 8px 8px 0;font-size:15px;line-height:1.7;color:#3D4A2E;margin-top:4px}
.cmp-tbl{width:100%;font-size:15px;border-collapse:collapse;margin-top:6px}
.cmp-tbl td{padding:9px 6px;border-bottom:1px solid var(--line)}
.cmp-tbl td:last-child{text-align:right;font-weight:700}
.checklist{list-style:none;font-size:15px;line-height:1.5}
.checklist li{display:flex;gap:9px;padding:8px 0;border-bottom:1px dashed var(--line);align-items:flex-start}
.checklist li:last-child{border:none}
.checklist .bx{width:18px;height:18px;border:1.5px solid var(--brand);border-radius:5px;flex:none;margin-top:1px;color:var(--brand);font-size:14px;text-align:center;line-height:16px;cursor:pointer}
.checklist .bx.on{background:var(--brand);color:#fff}
.trap{font-size:15px;line-height:1.6;color:#8A4B00;background:#FFF7E8;border:1px solid #FFE08A;border-radius:10px;padding:10px 12px;margin-top:8px;word-break:keep-all}

/* simulator */
.sim{background:linear-gradient(#fff,#fff) padding-box,linear-gradient(135deg,#163300,#0E2200) border-box;border:1.5px solid transparent;border-radius:14px;padding:16px;margin-top:13px}
.sim .simt{font-size:15px;font-weight:800;color:#0E2200;margin-bottom:4px}
.sim .simsub{font-size:13.5px;color:var(--sub);margin-bottom:12px;line-height:1.5}
.sim .ctrl{margin-bottom:12px}
.sim .ctrl label{font-size:14px;color:var(--sub);display:block;margin-bottom:6px}
.sim .ctrl .val{color:var(--brand);font-weight:800}
.sim input[type=range]{width:100%;accent-color:var(--brand)}
.sim .numrow{display:flex;gap:8px;align-items:center}
.sim .numrow input{flex:1;padding:9px 11px;border:1px solid var(--line);border-radius:9px;font-size:15.5px;font-family:inherit}
.sim .out{background:#161A14;color:#fff;border-radius:12px;padding:14px;margin-top:6px}
.sim .out .big{font-size:24px;font-weight:800;letter-spacing:-0.5px}
.sim .out .lb{font-size:13.5px;opacity:.8}
.sim .out .row2{display:flex;justify-content:space-between;font-size:14.5px;margin-top:8px;opacity:.92;line-height:1.6}
.sim .verdict{margin-top:10px;padding:10px 12px;border-radius:10px;font-size:15px;font-weight:700;text-align:center}
.sim .v-good{background:#E9F7EE;color:var(--good)}
.sim .v-bad{background:#FCEBEB;color:var(--bad)}
.sim .v-warn{background:#FFF7E8;color:var(--warn)}
.sim .savebtn{width:100%;margin-top:10px;padding:11px;background:#0E2200;color:#fff;border-radius:10px;font-size:15px;font-weight:700}
.sim .savebtn:active{opacity:.85}

/* ===== S12 mypage ===== */
#s12{background:var(--bg)}
#s12 .scroll{padding:16px 16px 40px}
.mp-hd{display:flex;align-items:center;justify-content:space-between;margin-bottom:4px}
.mp-hd h2{font-size:18px;font-weight:800}
.mp-prop{background:#fff;border:1px solid var(--line);border-radius:14px;padding:14px 16px;margin-top:10px;font-size:15px;line-height:1.7}
.mp-prop .addr{font-weight:700;font-size:15.5px}
.mp-prop .tax{color:var(--brand);font-weight:800}
.mp-sec-t{font-size:15.5px;font-weight:800;margin:20px 0 4px}
.arch-card{background:#fff;border:1px solid var(--line);border-radius:12px;padding:13px 14px;margin-top:10px}
.arch-card .ac-top{display:flex;justify-content:space-between;align-items:center}
.arch-card .ac-scn{font-size:15px;font-weight:700}
.arch-card .ac-when{font-size:13.5px;color:#9A9D92}
.arch-card .ac-head{font-size:15.5px;font-weight:800;color:var(--brand);margin-top:6px}
.arch-card .ac-param{font-size:14px;color:var(--sub);margin-top:5px;line-height:1.6}
.arch-card .ac-act{display:flex;gap:8px;margin-top:10px}
.arch-card .ac-act button{flex:1;padding:8px;border-radius:8px;font-size:14px;font-weight:700;border:1px solid var(--line);background:#fff;color:var(--ink)}
.arch-card .ac-act .del{color:var(--bad);border-color:#F6C9C9}
.mp-empty{text-align:center;color:var(--sub);font-size:15px;padding:24px 16px;line-height:1.7;background:#fff;border:1px dashed var(--line);border-radius:12px;margin-top:10px}
.mp-foot-note{font-size:13.5px;color:#9A9D92;text-align:center;margin-top:20px;line-height:1.6}
.paid-banner{background:linear-gradient(135deg,#1DA45A,#17A34A);color:#fff;font-size:14px;font-weight:700;text-align:center;padding:8px;border-radius:10px;margin-top:10px}
.dday-card{background:linear-gradient(135deg,#161A14,#2A3D1A);color:#fff;border-radius:16px;padding:16px 18px;margin-top:12px;text-align:center}
.dday-card .dd-l{font-size:14px;opacity:.85}
.dday-card .dd-n{font-size:34px;font-weight:800;letter-spacing:-1px;line-height:1.1;margin-top:2px}
.dday-card .dd-n span{font-size:16.5px;font-weight:700;margin-left:3px;opacity:.9}
.dday-card .dd-s{font-size:14px;opacity:.9;margin-top:7px;line-height:1.5;word-break:keep-all}
.dday-card .dd-alarm{margin-top:12px;width:100%;padding:11px;border-radius:10px;background:rgba(255,255,255,.14);color:#fff;font-size:15px;font-weight:700}
.dday-card .dd-alarm.on{background:#1DA45A}
.mp-alert{display:flex;gap:10px;background:#EFF3E9;border-radius:14px;padding:13px 15px;margin-top:10px;font-size:14.5px;line-height:1.6;color:var(--ink)}
.mp-alert b{color:var(--brand)}.mp-alert span{color:var(--sub)}

/* ===== 설문 게이트 ===== */
#sv{background:var(--bg)}
#sv .scroll{padding:18px 16px 110px}
.sv-hero{background:linear-gradient(135deg,#0E2200,#163300);color:#fff;border-radius:16px;padding:18px}
.sv-hero .t{font-size:18px;font-weight:800;letter-spacing:-0.3px}
.sv-hero .s{font-size:15px;opacity:.92;margin-top:8px;line-height:1.6;word-break:keep-all}
.sv-hero .badge{display:inline-block;background:rgba(255,255,255,.18);font-size:13.5px;font-weight:700;padding:4px 10px;border-radius:999px;margin-top:10px}
.sv-q{background:#fff;border:1px solid var(--line);border-radius:14px;padding:15px 16px;margin-top:12px}
.sv-q .ql{font-size:15.5px;font-weight:700;line-height:1.45;word-break:keep-all}
.sv-q .ql .req{color:var(--bad);font-size:14px;margin-left:3px}
.sv-q .qsub{font-size:14px;color:var(--sub);margin-top:3px}
.sv-opts{display:flex;flex-wrap:wrap;gap:8px;margin-top:11px}
.sv-opt{border:1.5px solid var(--line);background:#fff;color:var(--ink);font-size:15px;font-weight:600;padding:9px 13px;border-radius:10px;cursor:pointer}
.sv-opt.on{border-color:var(--brand);background:#EFF3E9;color:var(--brand)}
.sv-stars{display:flex;gap:6px;margin-top:11px}
.sv-star{font-size:30px;color:#CFCDC3;cursor:pointer;line-height:1}
.sv-star.on{color:#C77700}
.sv-q input[type=email],.sv-q textarea{width:100%;padding:11px;border:1px solid var(--line);border-radius:10px;font-size:16.5px;font-family:inherit;margin-top:10px}
.sv-q textarea{min-height:64px;resize:vertical;font-size:15.5px}
.sv-consent{display:flex;gap:8px;align-items:flex-start;font-size:14px;color:var(--sub);margin-top:11px;line-height:1.5}
.sv-consent input{margin-top:2px}
.sv-foot{position:absolute;left:0;right:0;bottom:0;background:#fff;border-top:1px solid var(--line);padding:11px 16px calc(12px + env(safe-area-inset-bottom))}
.sv-foot .note{font-size:13.5px;color:#9A9D92;text-align:center;margin-bottom:7px}
.sv-err{color:var(--bad);font-size:14px;text-align:center;margin-bottom:7px;min-height:14px}
.sv-value{background:#F4F7EF;border:1px solid #CFE0BE;border-radius:14px;padding:15px 16px;margin-top:12px}
.sv-value .svv-t{font-size:15px;font-weight:800;color:var(--brand);margin-bottom:9px}
.sv-value ul{list-style:none;margin:0;padding:0;font-size:14.5px;color:var(--ink);line-height:1.5}
.sv-value li{display:flex;gap:8px;align-items:flex-start;margin-bottom:7px;word-break:keep-all}
.sv-value li::before{content:'✓';color:var(--good);font-weight:800;flex:none}
.sv-slider{margin-top:14px}
.sv-slider input[type=range]{width:100%}
.sv-slider .sv-slider-val{text-align:center;font-size:20px;font-weight:800;color:var(--brand);margin-top:10px}
.sv-slider .sv-slider-cap{display:flex;justify-content:space-between;font-size:12.5px;color:var(--sub2);margin-top:4px}
</style>
</head>
<body>
<!-- Google Tag Manager (noscript) — 'GTM-XXXXXXX'를 실제 ID로 교체 -->
<noscript><iframe src="https://www.googletagmanager.com/ns.html?id=GTM-5JTC8935" height="0" width="0" style="display:none;visibility:hidden"></iframe></noscript>
<div id="frame">

<!-- ===== S01 ===== -->
<div class="screen on" id="s01">
  <div class="scroll">
   <div class="lp">
    <div class="lp-top">
      <div class="lp-brand"><img src="/logo_full_dark.png" alt="세꼼이"></div>
      <div class="lp-live"><i></i>세법 자동반영</div>
    </div>
    <div class="lp-hero">
      <div class="lp-eyebrow">집 한 채 팔 때, 가장 큰 변수</div>
      <h1 class="lp-h1">양도세 수천만 원,<br><span class="hl">꼼꼼하면 지킵니다</span></h1>
      <p class="lp-sub">비과세·장기보유·중과까지, 세꼼이가 내 상황에 맞춰 하나하나 따져요. <b>3분 대화</b>면 내가 얼마를 아낄 수 있는지 바로 나와요.</p>
      <div class="lp-steps">
        <div><b>묻고</b>11~19개<br>맞춤 질문</div>
        <div><b>계산하고</b>실제 세법<br>근거 공개</div>
        <div><b>줄이고</b>절세 시나리오<br>제안</div>
      </div>
    </div>
    <div class="lp-cta-wrap">
      <button class="lp-cta" id="startBtn">3분 만에 내 양도세 계산하기</button>
      <button class="lp-resume" id="resumeBtn" style="display:none">이어서 진행하기</button>
      <div class="lp-micro">무료 · 설치 없이 채팅으로 · 2026.7 최신 세법 반영</div>
      <a class="lp-blog" href="/blog/">양도세가 궁금하다면? 세꼼 블로그 보기 →</a>
    </div>
    <div class="lp-foot">
      <div class="fl"><a href="/blog/">블로그</a> · <a href="#" onclick="openLegal('privacy');return false">개인정보처리방침</a> · <a href="#" onclick="openLegal('terms');return false">이용약관</a></div>
      문의 <a href="mailto:sekkomi.com@gmail.com">sekkomi.com@gmail.com</a>
    </div>
   </div>
  </div>
</div>

<!-- ===== S02/S03 chat ===== -->
<div class="screen" id="s03">
  <div class="pbar"><i id="pfill"></i></div>
  <div class="scroll" id="chatScroll"></div>
  <div id="dock">
    <div class="hint" id="dockHint"></div>
    <div class="moneyrow"><input id="dockIn" inputmode="numeric" placeholder=""><button class="ok" id="dockOk">확인</button></div>
    <div class="kor" id="dockKor"></div>
    <div class="subchips" id="dockChips"></div>
  </div>
</div>

<!-- ===== S04 loading ===== -->
<div class="screen" id="s04">
  <div class="pbar"><i id="pfill4"></i></div>
  <div id="adFix" style="flex:none;padding:14px 18px 0"></div>
  <div class="scroll" id="loadScroll" style="padding:16px 18px 30px"></div>
</div>

<!-- ===== S05 result ===== -->
<div class="screen" id="s05"><div class="scroll" id="s05Body"></div></div>

<!-- ===== S06 preview ===== -->
<div class="screen" id="s06">
  <div class="s06-top">
    <div class="s06-nav"><button class="backbtn" id="s06Back">←</button><b style="font-size:15.5px">절세 시나리오</b></div>
    <div class="s06-tabs" id="s06Tabs"></div>
  </div>
  <div id="s06Body"></div>
  <div class="s06-foot">
    <div class="nmore" id="s06More"></div>
    <button class="btn-main gate-cta" onclick="openPaySheet()">설문 답하고 전체 시나리오 열기 (베타 무료)</button>
  </div>
</div>

<!-- ===== S07 list ===== -->
<div class="screen" id="s07">
  <div class="s06-top" style="padding-bottom:10px"><div class="s06-nav"><button class="backbtn" id="s07Back">←</button><b style="font-size:15.5px">전체 시나리오</b></div></div>
  <div class="scroll" id="s07Body"></div>
  <div class="s06-foot"><button class="btn-main gate-cta" onclick="openPaySheet()">설문 답하고 전체 시나리오 열기 (베타 무료)</button></div>
</div>

<!-- ===== S11 paid scenario consultation (chat) ===== -->
<div class="screen" id="s11">
  <div class="s11-top"><button class="backbtn" id="s11Back">←</button><span class="mid" id="s11Mid">절세 상담</span><button class="my" onclick="openMyPage()" title="마이페이지">☰</button></div>
  <div class="s11-tabs" id="s11Tabs"></div>
  <div class="s11-info" id="s11Info"></div>
  <div class="scroll" id="s11Chat"></div>
  <div id="s11Dock">
    <div class="hint" id="s11DockHint"></div>
    <div class="moneyrow"><input id="s11DockIn" inputmode="numeric"><button class="ok" id="s11DockOk">확인</button></div>
    <div class="kor" id="s11DockKor"></div>
  </div>
</div>

<!-- ===== S12 mypage ===== -->
<div class="screen" id="s12">
  <div class="s11-top"><button class="backbtn" id="s12Back">←</button><span class="mid">마이페이지</span><span style="width:26px"></span></div>
  <div class="scroll" id="s12Body"></div>
</div>

<!-- ===== 설문 게이트 ===== -->
<div class="screen" id="sv">
  <div class="s11-top"><button class="backbtn" id="svBack">←</button><span class="mid">베타 설문</span><span style="width:26px"></span></div>
  <div class="scroll" id="svBody"></div>
  <div class="sv-foot">
    <div class="sv-err" id="svErr"></div>
    <div class="note" id="svNote"></div>
    <button class="btn-main" id="svSubmit" onclick="submitSurvey()">제출하고 전체 시나리오 열기</button>
  </div>
</div>

<!-- modals -->
<div class="modal" id="addrModal"><div class="sheet">
  <h3>주소 검색</h3>
  <div id="addrEmbed" style="width:100%;height:60vh;min-height:340px;border:1px solid var(--line);border-radius:12px;overflow:hidden"></div>
  <div id="addrManual" style="display:none">
    <input class="addr-in" id="addrText" placeholder="예: 서울 강남구 역삼동" autocomplete="off">
    <div id="addrTextHint" style="font-size:13px;color:var(--sub2);margin-top:8px">시·구·동까지 적어주세요. 상세주소(동·호)는 안 적어도 돼요.</div>
    <button class="btn-main" id="addrTextOk" style="margin-top:12px">이 주소로 계속</button>
  </div>
  <button class="btn-ghost" id="addrManualToggle" style="margin-top:10px">검색이 안 되나요? 직접 입력하기</button>
  <button class="close" onclick="document.getElementById('addrModal').classList.remove('on')">닫기</button>
</div></div>

<div class="modal" id="helpModal"><div class="sheet">
  <h3 id="helpTitle">용어 풀이</h3>
  <div class="help-body" id="helpBody"></div>
  <button class="close" onclick="closeHelp()">닫기</button>
</div></div>

<div class="modal" id="legalModal"><div class="sheet">
  <h3 id="legalTitle"></h3>
  <div class="legal-body" id="legalBody"></div>
  <button class="close" onclick="document.getElementById('legalModal').classList.remove('on')">닫기</button>
</div></div>


</div>
<script>
/* ================= helpers ================= */
const $=s=>document.querySelector(s);
const sleep=ms=>new Promise(r=>setTimeout(r,ms));
let REPLAY=false, replayQueue=[];
const now=new Date(); const NOWY=now.getFullYear(), NOWM=now.getMonth()+1;
const ymNum=(y,m)=>y*12+m;
const monthsBetween=(a,b)=>ymNum(b.y,b.m)-ymNum(a.y,a.m);
function fmtMan(v){ // v in 만원
  v=Math.round(v);
  const neg=v<0; v=Math.abs(v);
  const eok=Math.floor(v/10000), man=v%10000;
  let s='';
  if(eok>0) s+=eok+'억'+(man>0?' ':'');
  if(man>0||eok===0) s+=man.toLocaleString()+'만';
  return (neg?'-':'')+s+'원';
}
function fmtYM(y,m){return y+'년 '+m+'월'}
function addMonths(y,m,k){const t=ymNum(y,m)+k;return {y:Math.floor((t-1)/12),m:((t-1)%12)+1}}

/* ====== state ====== */
let A={}; // answers
const SKEY='seggom_proto_v1';
function saveState(){A._savedAt=Date.now();localStorage.setItem(SKEY,JSON.stringify({log:answerLog,at:Date.now()}))}
let answerLog=[];
function logAns(v){answerLog.push(v);saveState()}

/* ====== screens ====== */
function show(id){document.querySelectorAll('.screen').forEach(e=>e.classList.remove('on'));$('#'+id).classList.add('on');updateGateBtns();}
/* 잠금 상태(PAID)에 따라 고정 게이트 버튼 문구 갱신 — 설문 완료자에겐 '설문' 문구 제거 */
function updateGateBtns(){try{document.querySelectorAll('.gate-cta').forEach(b=>{b.textContent=(typeof PAID!=='undefined'&&PAID)?'시나리오 상담 열기 →':'설문 답하고 전체 시나리오 열기 (베타 무료)';});}catch(e){}}
/* GTM/GA4 이벤트 전송 — dataLayer에 push (GTM 미연동 시 조용히 누적만) */
function track(ev,params){try{window.dataLayer=window.dataLayer||[];window.dataLayer.push(Object.assign({event:ev},params||{}));}catch(e){}}

/* ====== chat primitives ====== */
const chat=$('#chatScroll');
let firstBubbleOfTurn=true;
let GEN=0, ansIdx=0; // GEN: 답변 수정으로 흐름 재시작 시 이전 비동기 흐름 중단용
function scrollBottom(){chat.scrollTop=chat.scrollHeight}
async function bot(text,opt={}){
  const g=GEN;
  if(!REPLAY){
    const t=document.createElement('div');t.className='row-bot';
    t.innerHTML='<div class="avatar'+(firstBubbleOfTurn?'':' hide')+'">세</div><div class="typing"><s></s><s></s><s></s></div>';
    chat.appendChild(t);scrollBottom();
    await sleep(opt.slow?1000:650);
    t.remove();
    if(g!==GEN)throw new Error('stale-flow');
  }
  const r=document.createElement('div');r.className='row-bot';
  let inner=text.replace(/\?icon:(\w+)/g,(_,k)=>'<span class="qico" onclick="openHelp(\''+k+'\')">?</span>');
  r.innerHTML='<div class="avatar'+(firstBubbleOfTurn?'':' hide')+'">세</div><div class="bub">'+inner+(opt.sub?'<span class="sub">└ '+opt.sub+'</span>':'')+'</div>';
  chat.appendChild(r);scrollBottom();
  firstBubbleOfTurn=false;
}
function userSay(text){
  const r=document.createElement('div');r.className='row-user';
  r.innerHTML='<div class="bub-user" data-idx="'+(ansIdx++)+'" title="탭하면 이 답변부터 수정할 수 있어요">'+text+'</div>';
  chat.appendChild(r);scrollBottom();
  firstBubbleOfTurn=true;
}
/* 답변 수정: 사용자 풍선 탭 → 해당 답변부터 재진행 (이전 답변은 즉시 복원) */
chat.addEventListener('click',e=>{
  const b=e.target.closest('.bub-user');if(!b)return;
  editFrom(+b.dataset.idx);
});
function editFrom(idx){
  if(!confirm('이 답변부터 다시 진행할까요?\n(이후 답변은 분기가 바뀔 수 있어 다시 여쭤봐요)'))return;
  GEN++; // 진행 중이던 흐름 중단
  replayQueue=answerLog.slice(0,idx);
  answerLog=answerLog.slice(0,idx);
  saveState();
  REPLAY=replayQueue.length>0;
  A={};pCount=0;ansIdx=0;firstBubbleOfTurn=true;
  chat.innerHTML='';$('#dock').classList.remove('on');
  $('#pfill').style.width='0';
  flow().catch(()=>{});
}
function nextReplay(){if(replayQueue.length){return replayQueue.shift()}REPLAY=false;return undefined}

async function chips(list){ // [{label,value,help,small}]
  if(REPLAY){const v=nextReplay();if(v!==undefined){const it=list.find(x=>x.value===v);userSay(it?it.label.replace(/\?icon:\w+/,''):String(v));return v}}
  return new Promise(res=>{
    const w=document.createElement('div');w.className='chips';
    /* 선택지가 하나면 = 진행/행동 버튼 → 눈에 띄는 CTA로 */
    const isCta=list.length===1 && !list[0].small;
    if(isCta)w.classList.add('chips-cta');
    list.forEach(it=>{
      const m=it.label.match(/^(.*?)\s*\?icon:(\w+)\s*$/);
      const txt=m?m[1].trim():it.label;
      const b=document.createElement('button');b.className=(isCta?'chip cta':'chip')+(it.small?' sm':'');
      b.textContent=txt;
      b.onclick=()=>{w.remove();userSay(txt);logAns(it.value);res(it.value)};
      if(m){ // ? 는 같은 알약 안 분리 세그먼트 (오터치 방지 + 소속 명확)
        const pair=document.createElement('span');pair.className='chip-pair'+(it.small?' sm':'');
        const h=document.createElement('button');h.className='chip-help';h.textContent='?';
        h.onclick=()=>openHelp(m[2]);
        pair.appendChild(b);pair.appendChild(h);w.appendChild(pair);
      }else w.appendChild(b);
    });
    chat.appendChild(w);scrollBottom();
  });
}
async function dateYM(opt={}){ // returns {y,m,approx}
  if(REPLAY){const v=nextReplay();if(v!==undefined){userSay(fmtYM(v.y,v.m)+(v.approx?' (대략)':''));return v}}
  return new Promise(res=>{
    const w=document.createElement('div');w.className='inline-input';
    const y0=opt.minY||1990, y1=opt.maxY||NOWY+3;
    let ys='';for(let y=y1;y>=y0;y--)ys+='<option value="'+y+'">'+y+'년</option>';
    let ms='';for(let m=1;m<=12;m++)ms+='<option value="'+m+'">'+m+'월</option>';
    w.innerHTML='<div class="drum"><select class="yy">'+ys+'</select><select class="mm">'+ms+'</select></div><button class="ok">확인</button>'+(opt.forget?'<button class="forget">'+(opt.forgetLabel||'정확히 기억 안 나요')+'</button>':'');
    const dy=opt.defY||NOWY, dm=opt.defM||NOWM;
    w.querySelector('.yy').value=Math.min(Math.max(dy,y0),y1);w.querySelector('.mm').value=dm;
    let approx=false;
    w.querySelector('.ok').onclick=()=>{
      const v={y:+w.querySelector('.yy').value,m:+w.querySelector('.mm').value,approx};
      w.remove();userSay(fmtYM(v.y,v.m)+(approx?' (대략)':''));logAns(v);res(v);
    };
    if(opt.forget)w.querySelector('.forget').onclick=async()=>{
      approx=true;w.querySelector('.forget').style.display='none';
      if(opt.onForget)await opt.onForget();
      scrollBottom();
    };
    chat.appendChild(w);scrollBottom();
  });
}
async function yearsMonthsInput(opt={}){ // returns {months,approx}
  if(REPLAY){const v=nextReplay();if(v!==undefined){userSay(Math.floor(v.months/12)+'년 '+(v.months%12)+'개월'+(v.approx?' (대략)':''));return v}}
  return new Promise(res=>{
    const w=document.createElement('div');w.className='inline-input';
    w.innerHTML='<div class="ym"><input class="iy" inputmode="numeric" placeholder="0">년 <input class="im" inputmode="numeric" placeholder="0">개월</div><button class="ok">확인</button><button class="forget">잘 모르겠어요</button>';
    let approx=false;
    w.querySelector('.ok').onclick=()=>{
      const yv=+w.querySelector('.iy').value||0, mv=+w.querySelector('.im').value||0;
      if(yv===0&&mv===0&&!confirm('0개월로 입력할까요?'))return;
      const v={months:yv*12+mv,approx};
      w.remove();userSay(yv+'년 '+mv+'개월'+(approx?' (대략)':''));logAns(v);res(v);
    };
    w.querySelector('.forget').onclick=async()=>{approx=true;w.querySelector('.forget').style.display='none';if(opt.onForget)await opt.onForget();scrollBottom()};
    chat.appendChild(w);scrollBottom();
  });
}
/* bottom dock money input */
async function money(opt={}){ // returns 만원 number or special chip value
  if(REPLAY){const v=nextReplay();if(v!==undefined){userSay(typeof v==='number'?fmtMan(v):(v&&v.chip!==undefined?'(선택: '+v.chip+')':String(v)));return v}}
  return new Promise(res=>{
    const dock=$('#dock');dock.classList.add('on');
    $('#dockHint').textContent=opt.hint||'만원 단위로 입력해주세요';
    const inp=$('#dockIn');inp.value='';inp.placeholder=opt.placeholder||'예: 78000';
    $('#dockKor').textContent='';
    const chipsEl=$('#dockChips');chipsEl.innerHTML='';
    (opt.chips||[]).forEach(c=>{
      const m=c.label.match(/^(.*?)\s*\?icon:(\w+)\s*$/);
      const txt=m?m[1].trim():c.label;
      const b=document.createElement('button');b.className='chip sm';b.textContent=txt;
      b.onclick=()=>{cleanup();userSay(txt);logAns({chip:c.value});res({chip:c.value})};
      if(m){
        const pair=document.createElement('span');pair.className='chip-pair sm';
        const h=document.createElement('button');h.className='chip-help';h.textContent='?';
        h.onclick=()=>openHelp(m[2]);
        pair.appendChild(b);pair.appendChild(h);chipsEl.appendChild(pair);
      }else chipsEl.appendChild(b);
    });
    const F=opt.fmt||fmtMan;
    inp.oninput=()=>{const v=parseInt(inp.value.replace(/[^0-9]/g,''))||0;$('#dockKor').textContent=v?F(v):''};
    function cleanup(){dock.classList.remove('on');$('#dockOk').onclick=null;inp.oninput=null}
    $('#dockOk').onclick=()=>{
      const v=parseInt(inp.value.replace(/[^0-9]/g,''))||0;
      if(v<(opt.min??1)||v>(opt.max??2000000)){$('#dockHint').textContent=opt.rangeMsg||'1,000~1,000,000만원 사이로 입력해주세요';return}
      cleanup();userSay(F(v));logAns(v);res(v);
    };
    inp.focus();
  });
}

 {road:'대전 유성구 대학로 99',region:'대전 유성구',tag:'궁동'},
];
async function address(){
  if(REPLAY){const v=nextReplay();if(v!==undefined){userSay(v.road);return v}}
  return new Promise(res=>{
    const m=$('#addrModal');m.classList.add('on');
    const embed=$('#addrEmbed'), manual=$('#addrManual');
    function pick(a){ m.classList.remove('on'); userSay(a.road); logAns(a); res(a); }
    /* 직접 입력 (항상 가능한 안전 경로) */
    function useManual(){
      embed.style.display='none'; manual.style.display='block';
      const inp=$('#addrText'); inp.value='';
      $('#addrTextOk').onclick=()=>{
        const t=(inp.value||'').trim();
        if(t.length<4){$('#addrTextHint').textContent='시·구·동까지 적어주세요 (예: 서울 강남구 역삼동)';$('#addrTextHint').style.color='var(--bad)';return;}
        pick({road:t, region:t, tag:''}); /* region=전체문자열 → isAdj 부분매칭으로 조정지역 판정 */
      };
      setTimeout(()=>{try{inp.focus()}catch(e){}},60);
    }
    $('#addrManualToggle').onclick=useManual;
    /* 카카오(다음) 우편번호 위젯이 로드됐으면 실제 검색, 아니면 직접 입력 */
    if(window.daum&&window.daum.Postcode){
      embed.style.display='block'; manual.style.display='none'; embed.innerHTML='';
      try{
        new daum.Postcode({
          oncomplete:function(data){
            const road=(data.roadAddress||data.jibunAddress||data.address);
            const region=(data.sido+' '+data.sigungu).replace(/\s+/g,' ').trim();
            pick({road:road, region:region, tag:(data.bname||data.sigungu||'')});
          },
          width:'100%', height:'100%', maxSuggestItems:5
        }).embed(embed);
      }catch(e){ useManual(); }
    }else{
      useManual();
    }
  });
}
/* help */
const HELP={
